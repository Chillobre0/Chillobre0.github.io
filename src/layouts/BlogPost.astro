---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="post-shell">
			<article>
				<header class="post-header">
					<p class="eyebrow">文章</p>
					<h1>{title}</h1>
					<p class="post-description">{description}</p>
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span aria-hidden="true">/</span>
									<span>最后更新于 <FormattedDate date={updatedDate} /></span>
								</>
							)
						}
					</div>
				</header>

				{heroImage && <Image class="hero-image" width={1120} height={560} src={heroImage} alt="" />}

				<div class:list={['post-content', { 'without-toc': tocHeadings.length === 0 }]}>
					{
						tocHeadings.length > 0 && (
							<aside class="toc" aria-label="文章目录">
								<p>目录</p>
								<nav>
									{tocHeadings.map((heading) => (
										<a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
											{heading.text}
										</a>
									))}
								</nav>
							</aside>
						)
					}

					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-shell {
		width: min(1200px, calc(100% - 32px));
		padding-top: 24px;
	}

	.post-header {
		max-width: 720px;
		margin: 0 auto 1.2rem;
		text-align: center;
	}

	.post-header h1 {
		color: #17304f;
		font-size: clamp(1.55rem, 3.2vw, 2.35rem);
	}

	.post-description {
		max-width: 640px;
		margin: 0 auto 0.75rem;
		color: #5a7188;
		font-size: 0.98rem;
	}

	.post-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		color: #5a7188;
		font-size: 0.92rem;
	}

	.hero-image {
		display: block;
		width: 100%;
		aspect-ratio: 2 / 1;
		object-fit: cover;
		margin: 0 auto 1.5rem;
		border: 0;
		border-radius: 14px;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.14);
	}

	.post-content {
		display: grid;
		grid-template-columns: 180px minmax(0, 760px) 180px;
		gap: 1.25rem;
		align-items: start;
		justify-content: center;
	}

	.post-content.without-toc {
		display: block;
		max-width: 760px;
		margin: 0 auto;
	}

	.post-content.without-toc .prose {
		grid-column: auto;
		width: 100%;
	}

	.toc,
	.prose {
		border: 0;
		border-radius: 18px;
		background: #eaf3f8;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.14);
	}

	.toc {
		grid-column: 1;
		position: sticky;
		top: 92px;
		max-height: calc(100vh - 112px);
		overflow: auto;
		padding: 1rem;
	}

	.toc p {
		margin: 0 0 0.7rem;
		color: #214f88;
		font-size: 0.86rem;
		font-weight: 800;
	}

	.toc nav {
		display: grid;
		gap: 0.48rem;
	}

	.toc a {
		color: #516982;
		font-size: 0.88rem;
		line-height: 1.45;
		text-decoration: none;
	}

	.toc a:hover {
		color: #214f88;
	}

	.toc a.depth-3 {
		padding-left: 0.8rem;
		font-size: 0.84rem;
	}

	.prose {
		grid-column: 2;
		width: 100%;
		margin: 0 auto;
		padding: 2rem 2.2rem;
		color: #17304f;
	}

	.prose p,
	.prose ul,
	.prose ol,
	.prose li {
		color: #17304f;
	}

	.prose h1,
	.prose h2,
	.prose h3,
	.prose h4 {
		margin-top: 2.1rem;
		color: #17304f;
	}

	.prose a {
		color: #214f88;
		font-weight: 800;
	}

	.prose code {
		background: #d7e6f7;
		color: #214f88;
	}

	.prose > :first-child {
		margin-top: 0;
	}

	.prose > :last-child {
		margin-bottom: 0;
	}

	@media (max-width: 960px) {
		.post-content {
			grid-template-columns: 1fr;
		}

		.toc,
		.prose {
			grid-column: auto;
		}

		.toc {
			position: static;
			max-height: none;
		}
	}

	@media (max-width: 720px) {
		.prose {
			padding: 1.35rem;
		}
	}
</style>







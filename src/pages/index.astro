---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const links = [
	{
		title: 'GitHub',
		description: '代码仓库、项目记录和一些实验。',
		href: 'https://github.com/Chillobre0',
		label: '查看 GitHub',
	},
	{
		title: '哔哩哔哩',
		description: '以后可以放视频、学习记录或者个人动态。',
		href: 'https://space.bilibili.com/',
		label: '前往空间',
	},
	{
		title: '文章',
		description: '技术笔记、问题排查和阶段性复盘。',
		href: '/blog/',
		label: '阅读文章',
	},
	{
		title: '项目',
		description: '正在做的项目、练习和后续复盘。',
		href: '/projects/',
		label: '查看项目',
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-main">
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow">个人技术博客</p>
					<h1>Chillobre</h1>
					<p class="hero-summary">
						这里是我的个人网站，用来记录编程学习、项目实践、问题排查和一些阶段性思考。
						我希望它看起来清爽一点，也能清楚地留下每一次解决问题的过程。
					</p>
					<ul class="pill-list" aria-label="博客内容方向">
						<li>Web 开发</li>
						<li>学习笔记</li>
						<li>项目复盘</li>
						<li>工具使用</li>
					</ul>
				</div>

				<aside class="profile">
					<div class="avatar-wrap">
						<img src="/avatar.jpg" alt="Chillobre 的头像" />
					</div>
					<div class="profile-body">
						<p class="profile-label">Chillobre</p>
						<p>先把这个小站做成自己喜欢的样子，再上传 GitHub、部署上线、绑定域名。</p>
					</div>
				</aside>
			</section>

			<section class="link-panel" aria-label="常用入口">
				{
					links.map((link) => (
						<a class="link-card" href={link.href}>
							<span>{link.title}</span>
							<p>{link.description}</p>
							<strong>{link.label}</strong>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-main {
		display: grid;
		align-content: center;
		min-height: calc(100vh - 150px);
		padding: 28px 0;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.74fr);
		gap: 2rem;
		align-items: center;
	}

	.hero-copy {
		max-width: 680px;
	}

	.hero-summary {
		max-width: 620px;
		color: var(--text-muted);
		font-size: 1.04rem;
	}

	.profile {
		overflow: hidden;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.86);
		box-shadow: var(--shadow);
	}

	.avatar-wrap {
		position: relative;
		display: grid;
		place-items: center;
		min-height: 300px;
		background:
			radial-gradient(circle at 18% 18%, rgba(35, 207, 167, 0.24), transparent 28%),
			radial-gradient(circle at 86% 16%, rgba(26, 167, 236, 0.28), transparent 26%),
			linear-gradient(145deg, #f5fcff 0%, #dff8ff 100%);
	}

	.avatar-wrap::before,
	.avatar-wrap::after {
		position: absolute;
		width: 68px;
		height: 68px;
		border: 1px solid rgba(26, 167, 236, 0.22);
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.34);
		content: "";
	}

	.avatar-wrap::before {
		top: 34px;
		right: 42px;
	}

	.avatar-wrap::after {
		bottom: 36px;
		left: 38px;
	}

	.avatar-wrap img {
		position: relative;
		z-index: 1;
		width: min(230px, 68%);
		aspect-ratio: 1;
		border: 8px solid rgba(255, 255, 255, 0.9);
		border-radius: 50%;
		object-fit: cover;
		box-shadow: 0 18px 36px rgba(17, 137, 194, 0.2);
	}

	.profile-body {
		padding: 0.95rem 1rem 1.05rem;
	}

	.profile-label {
		margin-bottom: 0.25rem;
		color: var(--accent-strong);
		font-size: 0.85rem;
		font-weight: 800;
	}

	.profile-body p:last-child {
		margin-bottom: 0;
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.link-panel {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 1.25rem;
	}

	.link-card {
		display: block;
		min-height: 138px;
		padding: 1rem;
		border: 1px solid var(--line);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.78);
		color: var(--text);
		text-decoration: none;
		box-shadow: 0 8px 24px rgba(17, 137, 194, 0.08);
	}

	.link-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow);
	}

	.link-card span {
		display: block;
		margin-bottom: 0.45rem;
		color: var(--accent-strong);
		font-weight: 800;
	}

	.link-card p {
		margin-bottom: 0.8rem;
		color: var(--text-muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.link-card strong {
		color: var(--text);
		font-size: 0.9rem;
	}

	@media (max-width: 900px) {
		.home-main {
			display: block;
			min-height: auto;
		}

		.hero {
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.link-panel {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.link-panel {
			grid-template-columns: 1fr;
		}
	}
</style>

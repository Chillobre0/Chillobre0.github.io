---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const navItems = [
	{ icon: '01', text: '文章', href: '/blog/' },
	{ icon: '02', text: '项目', href: '/projects/' },
	{ icon: '03', text: '关于', href: '/about/' },
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="dashboard">
			<section class="side-card card">
				<div class="brand-row">
					<img src="/avatar.jpg" alt="Chillobre 的头像" />
					<div>
						<h1>Chillobre</h1>
						<p>个人博客目录</p>
					</div>
				</div>

				<nav class="side-nav" aria-label="首页导航">
					{
						navItems.map((item) => (
							<a href={item.href}>
								<span>{item.icon}</span>
								{item.text}
							</a>
						))
					}
				</nav>
			</section>

			<section class="hero-card card">
				<img src="/avatar.jpg" alt="Chillobre 的头像" />
				<p class="eyebrow">Welcome</p>
				<h2>你好，我是 Chillobre</h2>
				<p class="hero-desc">
					这里记录我的编程学习、项目实践、问题排查和阶段性思考。
					慢慢整理，也慢慢成长。
				</p>

				<div class="hero-links">
					<a href="https://github.com/Chillobre0" target="_blank" rel="noreferrer">
						<span>GitHub</span>
						<strong>代码仓库</strong>
					</a>
					<a href="https://space.bilibili.com/" target="_blank" rel="noreferrer">
						<span>Bilibili</span>
						<strong>视频主页</strong>
					</a>
				</div>
			</section>

			<section class="quote-card card">
				<p>悟已往之不谏，知来者之可追。实迷途其未远，觉今是而昨非。</p>
			</section>

			<section class="music-card card">
				<div class="music-icon">?</div>
				<div>
					<p>今日 BGM</p>
					<strong>Close To You</strong>
				</div>
				<button aria-label="播放音乐">?</button>
			</section>

			<a class="latest-card card card-link" href="/blog/why-build-blog/">
				<p>最新文章</p>
				<h3>我为什么重新搭建个人博客</h3>
				<span>记录重新开始搭建个人博客的原因。</span>
			</a>

			<a class="recommend-card card card-link" href="/blog/my-first-blog/">
				<p>推荐文章</p>
				<h3>我的第一篇博客</h3>
				<span>从这里开始，把想法和过程慢慢留下来。</span>
			</a>

			<a class="project-card card card-link" href="/projects/">
				<p>当前项目</p>
				<h3>Chillobre Blog</h3>
				<span>基于 Astro 的个人网站，正在持续完善中。</span>
			</a>
		</main>
		<Footer />
	</body>
</html>

<style>
	body {
		background: #dff1f5;
	}

	.dashboard {
		display: grid;
		grid-template-columns: 300px 460px 360px;
		grid-template-rows: 90px 135px 135px 160px;
		grid-template-areas:
			"side hero quote"
			"side hero latest"
			"side hero recommend"
			"music hero project";
		gap: 1.25rem;
		align-items: stretch;
		justify-content: center;
		min-height: calc(100vh - 150px);
		padding: 32px 0;
	}

	.card {
		position: relative;
		overflow: hidden;
		border: 0;
		border-radius: 18px;
		background: #3d6fb4;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.18);
		transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
	}

	.card:hover {
		transform: translateY(-3px);
		border-color: transparent;
		box-shadow: 0 22px 48px rgba(73, 82, 96, 0.24);
	}

	.card:active {
		transform: scale(0.985);
	}

	.card-link {
		display: block;
		color: inherit;
		text-decoration: none;
	}

	.side-card {
		grid-area: side;
		padding: 1.45rem;
		background: #3d6fb4;
	}

	.hero-card {
		grid-area: hero;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem;
		background: #3d6fb4;
		text-align: center;
	}

	.quote-card {
		grid-area: quote;
		display: flex;
		align-items: center;
		padding: 0.95rem 1.25rem;
		background: #3d6fb4;
	}

	.music-card {
		grid-area: music;
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 1.15rem;
		align-self: start;
		min-height: 120px;
		background: #315f9c;
	}

	.latest-card,
	.recommend-card,
	.project-card {
		padding: 1.15rem 1.25rem;
		background: #3d6fb4;
	}

	.latest-card {
		grid-area: latest;
	}

	.recommend-card {
		grid-area: recommend;
	}

	.project-card {
		grid-area: project;
		padding: 1.45rem 1.35rem;
		background: #3d6fb4;
	}

	.brand-row {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		margin-bottom: 1.35rem;
	}

	.brand-row img {
		width: 54px;
		height: 54px;
		border: 2px solid #e5eef8;
		border-radius: 50%;
		object-fit: cover;
	}

	.brand-row h1 {
		margin: 0;
		color: #ffffff;
		font-size: 1.55rem;
	}

	.brand-row p {
		margin: 0;
		color: #d7e4f2;
		font-size: 0.92rem;
	}

	.side-nav {
		display: grid;
		gap: 0.62rem;
	}

	.side-nav a {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.72rem 0.85rem;
		border-radius: 12px;
		color: #f4f8fc;
		font-weight: 700;
		text-decoration: none;
	}

	.side-nav a:hover {
		background: #315f9c;
		color: #ffffff;
	}

	.side-nav a:hover span {
		color: #ffffff;
	}

	.side-nav span {
		width: 1.5rem;
		color: #eaf3ff;
		font-size: 0.75rem;
		font-weight: 900;
		text-align: center;
	}

	.hero-card img {
		width: 112px;
		height: 112px;
		margin-bottom: 0.9rem;
		border: 6px solid #b8cfee;
		border-radius: 50%;
		object-fit: cover;
	}

	.hero-card h2 {
		margin-bottom: 0.65rem;
		color: #ffffff;
		font-size: clamp(1.85rem, 3.6vw, 2.7rem);
	}

	.hero-desc {
		max-width: 390px;
		margin: 0;
		color: #d7e4f2;
		font-size: 0.96rem;
	}

	.hero-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: min(100%, 360px);
		margin-top: 1.2rem;
	}

	.hero-links a {
		display: grid;
		gap: 0.15rem;
		padding: 0.85rem 1rem;
		border: 0;
		border-radius: 14px;
		background: #3d6fb4;
		color: #f4f8fc;
		text-align: left;
		text-decoration: none;
		transition: transform 160ms ease, background 160ms ease;
	}

	.hero-links a:hover {
		transform: translateY(-2px);
		background: #315f9c;
	}

	.hero-links span,
	.music-card p,
	.latest-card p,
	.recommend-card p,
	.project-card p {
		margin: 0 0 0.38rem;
		color: #eaf3ff;
		font-size: 0.9rem;
		font-weight: 800;
	}

	.hero-links strong {
		font-size: 0.95rem;
	}

	.quote-card p {
		margin: 0;
		color: #f4f8fc;
		font-size: 1.02rem;
		font-weight: 800;
		line-height: 1.55;
	}

	.music-icon {
		display: grid;
		place-items: center;
		width: 46px;
		height: 46px;
		flex: 0 0 auto;
		border-radius: 14px;
		background: #214f88;
		color: #eaf3ff;
		font-size: 1.4rem;
	}

	.music-card strong {
		display: block;
		color: #f4f8fc;
		font-size: 0.95rem;
	}

	.music-card button {
		margin-left: auto;
		width: 40px;
		height: 40px;
		border: 0;
		border-radius: 12px;
		background: #dff1f5;
		color: #eaf3ff;
		font-weight: 800;
		cursor: pointer;
	}

	.latest-card h3,
	.recommend-card h3,
	.project-card h3 {
		margin-bottom: 0.38rem;
		color: #ffffff;
		font-size: 1.04rem;
	}

	.latest-card span,
	.recommend-card span,
	.project-card span {
		color: #d7e4f2;
		font-size: 0.9rem;
		line-height: 1.55;
	}

	

	@media (max-width: 1180px) {
		.dashboard {
			grid-template-columns: 280px 420px 320px;
		}
	}

	@media (max-width: 980px) {
		.dashboard {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			grid-template-areas:
				"hero"
				"side"
				"music"
				"quote"
				"latest"
				"recommend"
				"project";
			width: min(100% - 24px, 720px);
			min-height: auto;
		}

		.music-card {
			align-self: stretch;
		}
	}

	@media (max-width: 560px) {
		.hero-links {
			grid-template-columns: 1fr;
		}
	}
</style>




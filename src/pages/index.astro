---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';


const navItems = [
	{ icon: '01', text: '文章', href: '/blog/' },
	{ icon: '02', text: '项目', href: '/projects/' },
	{ icon: '03', text: '关于', href: '/about/' },
];

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPost = posts[0];



---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="dashboard">
			<div class="left-column">
				<section class="side-card card">
					<div class="brand-row">
						<img src="/avatar.jpg" alt="Chillobre 的头像" />
						<div>
							<h1>Chillobre</h1>
							<p>个人博客目录</p>
						</div>
					</div>

					<nav class="side-nav" aria-label="首页导航">
						{
							navItems.map((item) => (
								<a href={item.href}>
									<span>{item.icon}</span>
									{item.text}
								</a>
							))
						}
					</nav>
				</section>

				<section class="music-card card">
					<div class="music-icon">♪</div>

					<div class="music-main">
						<p>今日 BGM</p>
						<strong>遗憾</strong>

						<button class="music-progress" id="music-progress" type="button" aria-label="调整音乐播放进度">
							<span id="music-progress-bar"></span>
						</button>
					</div>

					<button class="music-play" id="music-toggle" type="button" aria-label="播放音乐">▶</button>

					<audio id="bgm-audio" src="/music/pity.mp3"></audio>
				</section>
			</div>

			<section class="hero-card card">
				<img src="/avatar.jpg" alt="Chillobre 的头像" />
				<p class="eyebrow">——————Welcome——————</p>
				<h2>Hello</h2>
				<h2>I'm Chillobre</h2>
				<p class="hero-desc">
					这是我的个人博客，我会在这里分享项目和文章。
				</p>

				<div class="hero-links">
					<a href="https://github.com/Chillobre0" target="_blank" rel="noreferrer">
						<span>GitHub</span>
						<strong>代码仓库</strong>
					</a>
					<a href="https://space.bilibili.com/" target="_blank" rel="noreferrer">
						<span>Bilibili</span>
						<strong>视频主页</strong>
					</a>
				</div>
			</section>

			<div class="right-column">
				<section class="quote-card card">
					<p>悟已往之不谏，知来者之可追。实迷途其未远，觉今是而昨非。</p>
				</section>

				{
					latestPost && (
						<a class="latest-card card card-link" href={`/blog/${latestPost.id}/`}>
							<p>最新文章</p>
							<h3>{latestPost.data.title}</h3>
							<span>{latestPost.data.description}</span>
						</a>
					)
				}

				<a class="recommend-card card card-link" href="/blog/howto/">
					<p>推荐文章</p>
					<h3>怎么修改我的博客呢</h3>
					<span>push 的方法。</span>
				</a>

				<a class="project-card card card-link" href="/projects/">
					<p>当前项目</p>
					<h3>Chillobre Blog</h3>
					<span>基于 Astro 的个人网站，正在持续完善中。</span>
				</a>
			</div>
		</main>

		<Footer />

		<script>
			const audio = document.querySelector('#bgm-audio');
			const button = document.querySelector('#music-toggle');
			const progress = document.querySelector('#music-progress');
			const progressBar = document.querySelector('#music-progress-bar');

			function updateProgress() {
				if (!(audio instanceof HTMLAudioElement)) return;
				if (!(progressBar instanceof HTMLElement)) return;

				if (!audio.duration) {
					progressBar.style.width = '0%';
					return;
				}

				const percent = (audio.currentTime / audio.duration) * 100;
				progressBar.style.width = `${percent}%`;
			}

			button?.addEventListener('click', () => {
				if (!(audio instanceof HTMLAudioElement)) return;

				if (audio.paused) {
					audio.play();
					button.textContent = 'Ⅱ';
					button.setAttribute('aria-label', '暂停音乐');
				} else {
					audio.pause();
					button.textContent = '▶';
					button.setAttribute('aria-label', '播放音乐');
				}
			});

			progress?.addEventListener('click', (event) => {
				if (!(event instanceof MouseEvent)) return;
				if (!(audio instanceof HTMLAudioElement)) return;
				if (!(progress instanceof HTMLElement)) return;
				if (!audio.duration) return;

				const rect = progress.getBoundingClientRect();
				const clickX = event.clientX - rect.left;
				const percent = Math.min(Math.max(clickX / rect.width, 0), 1);

				audio.currentTime = audio.duration * percent;
				updateProgress();
			});


			audio?.addEventListener('timeupdate', updateProgress);

			audio?.addEventListener('ended', () => {
				if (!(button instanceof HTMLButtonElement)) return;
				if (!(progressBar instanceof HTMLElement)) return;

				button.textContent = '▶';
				button.setAttribute('aria-label', '播放音乐');
				progressBar.style.width = '0%';
			});
		</script>


	</body>
</html>

<style>
	body {
		background: #dff1f5;
	}

	.dashboard {
		display: grid;
		grid-template-columns: 300px 460px 360px;
		gap: 1.25rem;
		align-items: center;
		justify-content: center;
		min-height: calc(100vh - 150px);
		padding: 32px 0;
	}

	.left-column,
	.right-column {
		display: grid;
		gap: 1.25rem;
		align-content: center;
	}


	.card {
		position: relative;
		overflow: hidden;
		border: 0;
		border-radius: 18px;
		background: #3d6fb4;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.18);
		transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
	}

	.card:hover {
		transform: translateY(-3px);
		border-color: transparent;
		box-shadow: 0 22px 48px rgba(73, 82, 96, 0.24);
	}

	.card:active {
		transform: scale(0.985);
	}

	.card-link {
		display: block;
		color: inherit;
		text-decoration: none;
	}
 

	/* 修改长度 */
	.side-card {
		padding: 1.45rem;
		min-height: 360px;
		background: #3d6fb4;
	}

	.music-card {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		padding: 1.15rem;
		min-height: 145px;
		background: #315f9c;
	}

	.hero-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 600px;
		padding: 2rem;
		text-align: center;
		background: #3d6fb4;
	}

	.quote-card {
		display: flex;
		align-items: center;
		min-height: 95px;
		padding: 0.95rem 1.25rem;
		background: #3d6fb4;
	}

	.latest-card,
	.recommend-card {
		padding: 1.15rem 1.25rem;
		min-height: 135px;
		background: #3d6fb4;
	}

	.project-card {
		padding: 1.45rem 1.35rem;
		min-height: 150px;
		background: #3d6fb4;
	}


	.brand-row {
		display: flex;
		align-items: center;
		gap: 0.9rem;
		margin-bottom: 1.35rem;
	}

	.brand-row img {
		width: 54px;
		height: 54px;
		border: 2px solid #e5eef8;
		border-radius: 50%;
		object-fit: cover;
	}

	.brand-row h1 {
		margin: 0;
		color: #ffffff;
		font-size: 1.55rem;
	}

	.brand-row p {
		margin: 0;
		color: #d7e4f2;
		font-size: 0.92rem;
	}

	.side-nav {
		display: grid;
		gap: 0.62rem;
	}

	.side-nav a {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		padding: 0.72rem 0.85rem;
		border-radius: 12px;
		color: #f4f8fc;
		font-weight: 700;
		text-decoration: none;
	}

	.side-nav a:hover {
		background: #315f9c;
		color: #ffffff;
	}

	.side-nav a:hover span {
		color: #5587c0;
	}

	.side-nav span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.3rem;
		height: 2.3rem;
		flex: 0 0 auto;
		border-radius: 12px;
		background: #dff1f5;
		color: #214f88;
		font-size: 0.78rem;
		font-weight: 900;
		text-align: center;
	}


	.hero-card img {
		width: 112px;
		height: 112px;
		margin-bottom: 0.9rem;
		border: 6px solid #b8cfee;
		border-radius: 50%;
		object-fit: cover;
	}

	.hero-card h2 {
		margin-bottom: 0.65rem;
		color: #ffffff;
		font-size: clamp(1.85rem, 3.6vw, 2.7rem);
	}

	.hero-desc {
		max-width: 390px;
		margin: 0;
		color: #d7e4f2;
		font-size: 0.96rem;
	}

	.hero-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: min(100%, 360px);
		margin-top: 1.2rem;
	}

	.hero-links a {
		display: grid;
		gap: 0.15rem;
		padding: 0.85rem 1rem;
		border: 0;
		border-radius: 14px;
		background: #3d6fb4;
		color: #f4f8fc;
		text-align: left;
		text-decoration: none;
		transition: transform 160ms ease, background 160ms ease;
	}

	.hero-links a:hover {
		transform: translateY(-2px);
		background: #315f9c;
	}

	.hero-links span,
	.music-card p,
	.latest-card p,
	.recommend-card p,
	.project-card p {
		margin: 0 0 0.38rem;
		color: #eaf3ff;
		font-size: 0.9rem;
		font-weight: 800;
	}

	.hero-links strong {
		font-size: 0.95rem;
	}

	.quote-card p {
		margin: 0;
		color: #f4f8fc;
		font-size: 1.02rem;
		font-weight: 800;
		line-height: 1.55;
	}

	.music-icon {
		display: grid;
		place-items: center;
		width: 46px;
		height: 46px;
		flex: 0 0 auto;
		border-radius: 14px;
		background: #214f88;
		color: #eaf3ff;
		font-size: 1.4rem;
	}

	.music-card strong {
		display: block;
		color: #f4f8fc;
		font-size: 0.95rem;
	}

	.music-main {
		flex: 1;
		min-width: 0;
	}

	.music-progress {
		display: block;
		width: 100%;
		height: 8px;
		margin-top: 0.55rem;
		padding: 0;
		overflow: hidden;
		border: 0;
		border-radius: 999px;
		background: rgba(223, 241, 245, 0.45);
		cursor: pointer;
	}

	#music-progress-bar {
		display: block;
		width: 0%;
		height: 100%;
		border-radius: inherit;
		background: #dff1f5;
		transition: width 180ms linear;
	}



	.music-play {
		margin-left: auto;
		width: 48px;
		height: 48px;
		border: 0;
		border-radius: 14px;
		background: #dff1f5;
		color: #214f88;
		font-size: 1.35rem;
		font-weight: 800;
		cursor: pointer;
		display: grid;
		place-items: center;
		line-height: 1;
	}



	.latest-card h3,
	.recommend-card h3,
	.project-card h3 {
		margin-bottom: 0.38rem;
		color: #ffffff;
		font-size: 1.04rem;
	}

	.latest-card span,
	.recommend-card span,
	.project-card span {
		color: #d7e4f2;
		font-size: 0.9rem;
		line-height: 1.55;
	}

	

	@media (max-width: 1180px) {
		.dashboard {
			grid-template-columns: 280px 420px 320px;
		}
	}

	@media (max-width: 980px) {
		.dashboard {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			grid-template-areas:
				"hero"
				"side"
				"music"
				"quote"
				"latest"
				"recommend"
				"project";
			width: min(100% - 24px, 720px);
			min-height: auto;
		}

		.music-card {
			align-self: stretch;
		}
	}

	@media (max-width: 560px) {
		.hero-links {
			grid-template-columns: 1fr;
		}
	}
</style>




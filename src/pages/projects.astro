---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const projects = [
	{
		name: 'Chillobre Blog',
		status: '进行中',
		description: '基于 Astro 搭建的个人技术博客，用来记录文章、项目和学习过程。',
		tags: ['Astro', 'Markdown', '个人网站'],
	},


];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`项目 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-title">
				<p class="eyebrow">Projects</p>
				<h1>项目</h1>
				<p>这里会放我正在做、已经完成，或者值得复盘的项目。</p>
			</section>

			<ul class="project-grid">
				{
					projects.map((project) => (
						<li class="project-card">
							<div class="project-card-head">
								<h2>{project.name}</h2>
								<span>{project.status}</span>
							</div>
							<p>{project.description}</p>
							<ul class="tag-list">
								{project.tags.map((tag) => (
									<li>{tag}</li>
								))}
							</ul>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	.page-title h1,
	.page-title p:last-child {
		color: #17304f;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.project-card {
		padding: 1.25rem;
		border: 0;
		border-radius: 18px;
		background: #3d6fb4;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.18);
	}

	.project-card-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.project-card h2 {
		color: #ffffff;
		font-size: 1.2rem;
	}

	.project-card-head span {
		flex: 0 0 auto;
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
		background: #dff1f5;
		color: #214f88;
		font-size: 0.78rem;
		font-weight: 800;
	}

	.project-card p {
		color: #d7e4f2;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 0.25rem 0.55rem;
		border: 0;
		border-radius: 999px;
		background: #315f9c;
		color: #eaf3ff;
		font-size: 0.82rem;
	}

	@media (max-width: 900px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>


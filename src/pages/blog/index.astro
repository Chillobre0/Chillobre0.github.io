---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const categories = [
	{
		name: '日常感想',
		description: '生活、学习、建站过程，还有一些阶段性的想法。',
	},
	{
		name: '考研记录',
		description: '复习计划、学习状态、资料整理和备考复盘。',
	},
	{
		name: '实习记录',
		description: '实习经历、工作记录、项目经验和成长笔记。',
	},
];

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const groupedPosts = categories.map((category) => ({
	...category,
	posts: posts.filter((post) => (post.data.category ?? '日常感想') === category.name),
}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-title">
				<p class="eyebrow">文章归档</p>
				<h1>文章</h1>
				<p>这里会慢慢整理 Chillobre 的日常感想、考研记录和实习记录。</p>
			</section>

			<section class="category-grid">
				{
					groupedPosts.map((category, index) => (
						<section class="category-column">
							<div class="category-header">
								<span>{String(index + 1).padStart(2, '0')}</span>
								<div>
									<h2>{category.name}</h2>
									<p>{category.description}</p>
								</div>
							</div>

							{
								category.posts.length > 0 ? (
									<ul class="post-list">
										{category.posts.map((post) => (
											<li class="article-card">
												<a href={`/blog/${post.id}/`}>
													<p class="muted">
														<FormattedDate date={post.data.pubDate} />
													</p>
													<h3>{post.data.title}</h3>
													<p>{post.data.description}</p>
												</a>
											</li>
										))}
									</ul>
								) : (
									<p class="empty-text">这里暂时还没有文章。</p>
								)
							}
						</section>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		max-width: 760px;
		margin-bottom: 2rem;
	}

	.page-title h1,
	.page-title p:last-child {
		color: #17304f;
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		align-items: start;
	}

	.category-column {
		min-height: 280px;
		padding: 1.15rem;
		border: 0;
		border-radius: 18px;
		background: #3d6fb4;
		box-shadow: 0 18px 42px rgba(73, 82, 96, 0.18);
	}

	.category-header {
		display: flex;
		gap: 0.8rem;
		align-items: flex-start;
		margin-bottom: 1rem;
	}

	.category-header span {
		display: inline-flex;
		width: 2.3rem;
		height: 2.3rem;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		border-radius: 12px;
		background: #dff1f5;
		color: #214f88;
		font-size: 0.85rem;
		font-weight: 800;
	}

	.category-header h2 {
		margin: 0;
		color: #f4f8fc;
		font-size: 1.15rem;
	}

	.category-header p {
		margin: 0.35rem 0 0;
		color: #d7e4f2;
		font-size: 0.9rem;
		line-height: 1.6;
	}

	.post-list {
		display: grid;
		gap: 0.8rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.article-card {
		border: 0;
		border-radius: 14px;
		background: #315f9c;
		box-shadow: none;
		transition: transform 160ms ease, background 160ms ease;
	}

	.article-card:hover {
		transform: translateY(-3px);
		background: #2b568e;
	}

	.article-card a {
		display: block;
		padding: 1rem;
		text-decoration: none;
		color: #f4f8fc;
	}

	.article-card h3 {
		margin: 0.35rem 0;
		color: #ffffff;
		font-size: 1rem;
		line-height: 1.45;
	}

	.article-card p,
	.article-card .muted {
		margin: 0;
		color: #d7e4f2;
		font-size: 0.92rem;
		line-height: 1.65;
	}

	.empty-text {
		margin: 0;
		padding: 1rem;
		border-radius: 14px;
		background: #315f9c;
		color: #d7e4f2;
		font-size: 0.92rem;
	}

	@media (max-width: 980px) {
		.category-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

